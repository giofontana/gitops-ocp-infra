# iDRAC Credentials
IDRAC_USERNAME=root
IDRAC_PASSWORD=xxxxxxx
IDRAC_VERIFY_CERTS=false

# SSH Credentials (for nodes without iDRAC)
SSH_USER=core
SSH_KEY=/path/to/ssh-key

# Hosts - format: name:host_ip:idrac_ip (idrac_ip optional)
HOSTS=node1:192.168.101.11:192.168.100.11,node2:192.168.101.12:192.168.100.12,node3:192.168.101.13

# Timeouts (all optional, defaults in code)
DRAIN_TIMEOUT=60
POWER_OFF_POLL_INTERVAL=30
POWER_OFF_POLL_MAX_ATTEMPTS=30
