# iDRAC Credentials
IDRAC_USERNAME=root
IDRAC_PASSWORD=xxxxxxx
IDRAC_VERIFY_CERTS=false

# Hosts - format: name:host:idrac_host (idrac_host optional)
HOSTS=node1:192.168.101.11:192.168.100.11,yyyy:192.168.101.12:192.168.100.12,zzzz:192.168.101.13:192.168.100.13,aaaaa:192.168.101.14

# Timeouts (all optional, defaults in code)
POWER_ON_POLL_INTERVAL=5
POWER_ON_POLL_MAX_ATTEMPTS=60
OCP_API_RETRY_DELAY=60
OCP_API_MAX_RETRIES=20
OCP_SETTLE_PAUSE=60
